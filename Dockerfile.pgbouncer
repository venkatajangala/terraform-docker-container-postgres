FROM debian:bookworm-slim

# Add PostgreSQL apt repository for PostgreSQL 18 client tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    gnupg \
    curl \
    && sh -c 'echo "deb http://apt.postgresql.org/pub/repos/apt bookworm-pgdg main" > /etc/apt/sources.list.d/pgdg.list' \
    && curl https://www.postgresql.org/media/keys/ACCC4CF8.asc | apt-key add - \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
    pgbouncer \
    postgresql-client-18 \
    netcat-openbsd \
    jq \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Create pgbouncer user and directories
RUN mkdir -p /etc/pgbouncer /var/log/pgbouncer && \
    chown -R postgres:postgres /etc/pgbouncer /var/log/pgbouncer && \
    chmod 750 /etc/pgbouncer

# Expose PgBouncer port
EXPOSE 6432

# Health check - verify connection
HEALTHCHECK --interval=10s --timeout=5s --start-period=10s --retries=3 \
    CMD psql -h localhost -p 6432 -U pgadmin -d postgres -c "SELECT 1" || exit 1

# Copy entrypoint script
COPY entrypoint-pgbouncer.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/entrypoint-pgbouncer.sh

# Start PgBouncer in foreground to Docker logs
ENTRYPOINT ["/usr/local/bin/entrypoint-pgbouncer.sh"]
